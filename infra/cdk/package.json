{
  "name": "@primedhealth/cdk",
  "version": "0.0.0",
  "private": true,
  "description": "AWS CDK infrastructure for PrimedHealth.",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "synth:dev": "cdk synth -c env=dev",
    "synth:prod": "cdk synth -c env=prod",
    "diff:dev": "cdk diff -c env=dev",
    "diff:prod": "cdk diff -c env=prod",
    "deploy:dev": "cdk deploy -c env=dev --all",
    "deploy:prod": "cdk deploy -c env=prod --all",
    "destroy:dev": "cdk destroy -c env=dev --all"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.170.0",
    "cdk-nag": "^2.30.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/source-map-support": "^0.5.10",
    "aws-cdk": "^2.170.0",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
