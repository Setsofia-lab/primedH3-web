{
  "name": "@primedhealth/api",
  "version": "0.0.0",
  "private": true,
  "description": "PrimedHealth API — NestJS REST + OpenAPI. Implemented in Phase 2 M4.",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "migrate:generate": "drizzle-kit generate",
    "migrate:run": "tsx src/db/migrate.ts",
    "openapi:emit": "tsx scripts/emit-openapi.ts",
    "seed:agents": "tsx scripts/seed-agents.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1037.0",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/client-secrets-manager": "^3.900.0",
    "@aws-sdk/client-sqs": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/static": "^8.1.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@primedhealth/shared-types": "workspace:*",
    "aws-jwt-verify": "^5.1.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.1",
    "nestjs-pino": "^4.2.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
