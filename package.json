{
  "name": "primedhealth",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @primedhealth/web dev",
    "build": "pnpm -r --if-present build",
    "start": "pnpm --filter @primedhealth/web start",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test:unit": "pnpm -r --if-present test:unit",
    "openapi:emit": "pnpm --filter @primedhealth/api openapi:emit",
    "openapi:gen": "pnpm --filter @primedhealth/shared-types gen",
    "openapi:sync": "pnpm openapi:emit && pnpm openapi:gen",
    "test:e2e": "pnpm --filter @primedhealth/web test:e2e",
    "storybook": "pnpm --filter @primedhealth/web storybook",
    "build-storybook": "pnpm --filter @primedhealth/web build-storybook",
    "test-storybook": "pnpm --filter @primedhealth/web test-storybook",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "secrets:scan": "gitleaks detect --config .gitleaks.toml --verbose"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.8.3"
  }
}
